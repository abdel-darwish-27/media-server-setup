# PIA credentials in compose file
# (if you ever accidentally commit credentials, rotate them immediately)
# docker-compose.yml  ← not ignored so it's version-controlled, BUT verify credentials are stripped before pushing!

# Config data with potential secrets
config/gluetun/

# Large binary data
config/plex/Library/
config/*/logs/
config/*/Sentry/
config/*/asp/
config/*/Definitions/
config/qbittorrent/.cache/
config/qbittorrent/cache/
config/qbittorrent/data/
config/qbittorrent/wireguard/

# Media
downloads/
movies/
tv/

# Backups
*.tar.gz
docker-compose.yml

# Allow templates
!docker-compose.template.yml
!.env.example
!config/*/config.template.xml

# Runtime config files (DBs, logs, cache, PIDs)
config/**/*.db
config/**/*.db-shm
config/**/*.db-wal
config/**/*.db.bak
config/**/*.pid
config/**/logs/
config/**/logs/*
config/**/log.db
config/**/xdg/
config/**/MediaCover/
config/**/lockfile
config/**/qBittorrent-data.conf
config/**/qBittorrent.conf.bak
config/**/feeds.json
config/**/categories.json
config/**/watched_folders.json
config/**/web_clientdata.json
config/**/pia-*.json
config/**/pia-*
config/**/.cache/
config/gluetun/
